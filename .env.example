# ============================================================
# Agentic Deep Research -- environment configuration
# ============================================================
# Copy this file to .env and fill in any keys you have. None are
# strictly required: without web-search keys the pipeline falls
# back to arxiv + Wikipedia + DuckDuckGo only.
#
#     cp .env.example .env
#     source .env   # or use direnv / a launcher script
# ============================================================

# ---------- Web search providers (optional) ----------

# Tavily -- AI-friendly web search, best quality after arxiv/wiki.
# Free tier: 1000 queries/month. Sign up at https://tavily.com
TAVILY_API_KEY=

# Brave Search -- alternative web provider, kicks in when Tavily is exhausted.
# Free tier: 2000 queries/month. Sign up at https://brave.com/search/api/
BRAVE_API_KEY=

# ---------- Pipeline model overrides (optional) ----------

# Writer model (the one that drafts each section). Default: gemma3:4b.
# Recommended upgrades for better synthesis on a 4B/8B Mac:
#   qwen2.5:7b   (~4.7 GB, better instruction-following + citation density)
#   qwen2.5:14b  (~9 GB,   noticeable jump in synthesis quality)
# DEEP_RESEARCH_WRITER_MODEL=qwen2.5:7b

# ---------- Runner controls (optional) ----------

# Set to 1 to enable the LLM-as-judge review pass (depth/coherence/format scoring).
# Adds ~10-15s per section.
# DEEP_RESEARCH_REVIEW=1

# Output file basename. Set to e.g. "book2" to produce book2.{md,html,pdf,...}
# instead of overwriting the default book.* outputs.
# DEEP_RESEARCH_OUT_NAME=book2

# Stage 3 planner -- generate the CHAPTERS outline from a topic instead of using
# the hardcoded LLM outline. Requires arxiv/wiki at minimum (web search recommended).
# DEEP_RESEARCH_TOPIC="Diffusion Models for Image Generation"

# Planner outline shape (when DEEP_RESEARCH_TOPIC is set).
# DEEP_RESEARCH_N_CHAPTERS=12
# DEEP_RESEARCH_N_PASSES=8

# End-chapter limit -- run only the first N chapters. Useful for smoke testing.
# DEEP_RESEARCH_END_CH=1
